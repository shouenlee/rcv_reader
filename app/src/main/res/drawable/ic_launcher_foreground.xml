<?xml version="1.0" encoding="utf-8"?>
<!--
  3D closed book: crimson rounded front cover, gold spine face, cream top/pages face.
  Viewport 108dp. Safe zone center 72dp (18dp inset each side).
  Book fills ~80% of safe zone. Depth offset: (-11, -7).

  Front face corners:  TL(30,26) TR(86,26) BR(86,90) BL(30,90)
  Back face corners:   TL(19,19) TR(75,19) BR(75,83) BL(19,83)
  Faces drawn back→front: top, spine, cover.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ambient warm glow behind book -->
    <path android:pathData="M54,65 m-42,0 a42,28 0 1,0 84,0 a42,28 0 1,0 -84,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="65" android:gradientRadius="42">
                <item android:offset="0.0" android:color="#38C49B5E"/>
                <item android:offset="0.6" android:color="#10C49B5E"/>
                <item android:offset="1.0" android:color="#00C49B5E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ① Top face — pages (cream parallelogram: front→back) -->
    <!-- Front edge: (30,26)→(86,26)  Back edge: (19,19)→(75,19) -->
    <path android:pathData="M30,26 L86,26 L75,19 L19,19 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="86" android:startY="26"
                android:endX="19"   android:endY="19">
                <item android:offset="0.0" android:color="#FFE0D8C8"/>
                <item android:offset="1.0" android:color="#FFB8B0A0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Page edge lines on top face -->
    <path
        android:pathData="M28.4,24.2 L84.4,24.2 M26.8,22.4 L82.8,22.4 M25.2,20.6 L81.2,20.6"
        android:strokeColor="#C0B8A8"
        android:strokeWidth="0.4"
        android:strokeAlpha="0.5"
        android:fillColor="#00000000"/>

    <!-- ② Spine face — gold parallelogram -->
    <!-- Points: front-top(30,26), back-top(19,19), back-bottom(19,83), front-bottom(30,90) -->
    <path android:pathData="M30,26 L19,19 L19,83 L30,90 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="19" android:startY="19"
                android:endX="30"   android:endY="90">
                <item android:offset="0.0" android:color="#FFF0D080"/>
                <item android:offset="0.5" android:color="#FFC49B5E"/>
                <item android:offset="1.0" android:color="#FF7A5020"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Spine inner shadow (right edge of spine face, subtle dark strip) -->
    <path android:pathData="M28,26 L19,19 L19,83 L28,90 Z"
          android:fillColor="#55180800"/>

    <!-- ③ Front cover — crimson, corners rounded r=5 -->
    <!-- TL(30,26) TR(86,26) BR(86,90) BL(30,90) -->
    <path android:pathData="M35,26 L81,26 Q86,26 86,31 L86,85 Q86,90 81,90 L35,90 Q30,90 30,85 L30,31 Q30,26 35,26 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="38" android:startY="26"
                android:endX="80"   android:endY="90">
                <item android:offset="0.0" android:color="#FFC03030"/>
                <item android:offset="0.45" android:color="#FF8C1C1C"/>
                <item android:offset="1.0" android:color="#FF520E0E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cover sheen — subtle diagonal highlight top-left -->
    <path android:pathData="M35,26 L81,26 Q86,26 86,31 L86,85 Q86,90 81,90 L35,90 Q30,90 30,85 L30,31 Q30,26 35,26 Z"
          android:fillAlpha="1">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="30" android:startY="26"
                android:endX="70"   android:endY="66">
                <item android:offset="0.0" android:color="#18FFFFFF"/>
                <item android:offset="0.5" android:color="#06FFFFFF"/>
                <item android:offset="1.0" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cover inset border ornament -->
    <path android:pathData="M35,31 L81,31 Q84,31 84,34 L84,83 Q84,86 81,86 L35,86 Q32,86 32,83 L32,34 Q32,31 35,31 Z"
          android:fillColor="#00000000"
          android:strokeColor="#C49B5E"
          android:strokeWidth="0.6"
          android:strokeAlpha="0.30"/>

    <!-- Corner accent dots -->
    <path android:pathData="M35,33 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.40"/>
    <path android:pathData="M81,33 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.40"/>
    <path android:pathData="M35,84 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.40"/>
    <path android:pathData="M81,84 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.40"/>

    <!-- Thin horizontal accent line near top of cover -->
    <path android:pathData="M32,38 L84,38"
          android:strokeColor="#C49B5E"
          android:strokeWidth="0.6"
          android:strokeAlpha="0.20"
          android:fillColor="#00000000"/>

    <!-- ④ Spine highlight edge — bright gold line where spine meets cover -->
    <path android:pathData="M30,26 L30,90"
          android:strokeWidth="1.6"
          android:strokeAlpha="0.75"
          android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="30" android:startY="26"
                android:endX="30"   android:endY="90">
                <item android:offset="0.0" android:color="#FFF8E8A0"/>
                <item android:offset="1.0" android:color="#FFC49B5E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-front edge highlight -->
    <path android:pathData="M30,26 L86,26"
          android:strokeColor="#F2D488"
          android:strokeWidth="0.8"
          android:strokeAlpha="0.30"
          android:fillColor="#00000000"/>

</vector>
