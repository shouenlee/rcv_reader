<?xml version="1.0" encoding="utf-8"?>
<!--
  3D closed book — all geometry scaled to fit within the 66dp safe-zone circle
  (radius 33dp from centre 54,54). Farthest point is back-TL at (31,31) = 32.5dp.

  108dp viewport. Faces drawn back→front: top/pages, spine, front cover.
  Front face: TL(38,35) TR(75,35) BR(75,78) BL(38,78)  37dp wide × 43dp tall
  Back face:  TL(31,31) TR(68,31) BR(68,73) BL(31,73)  depth offset (-7,-4)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ambient warm glow -->
    <path android:pathData="M54,60 m-35,0 a35,22 0 1,0 70,0 a35,22 0 1,0 -70,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="60" android:gradientRadius="35">
                <item android:offset="0.0" android:color="#38C49B5E"/>
                <item android:offset="0.6" android:color="#10C49B5E"/>
                <item android:offset="1.0" android:color="#00C49B5E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ① Top face — pages (parallelogram: front-edge→back-edge) -->
    <!-- front: (38,35)→(75,35)   back: (31,31)→(68,31) -->
    <path android:pathData="M38,35 L75,35 L68,31 L31,31 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="75" android:startY="35"
                android:endX="31"   android:endY="31">
                <item android:offset="0.0" android:color="#FFE0D8C8"/>
                <item android:offset="1.0" android:color="#FFB0A898"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Page stack lines on top face -->
    <path
        android:pathData="M36.6,33.4 L73.6,33.4 M35.2,31.8 L72.2,31.8"
        android:strokeColor="#C0B8A8"
        android:strokeWidth="0.4"
        android:strokeAlpha="0.5"
        android:fillColor="#00000000"/>

    <!-- ② Spine face — gold parallelogram -->
    <!-- front-top(38,35) back-top(31,31) back-bottom(31,73) front-bottom(38,78) -->
    <path android:pathData="M38,35 L31,31 L31,73 L38,78 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="31" android:startY="31"
                android:endX="38"   android:endY="78">
                <item android:offset="0.0" android:color="#FFF0D080"/>
                <item android:offset="0.5" android:color="#FFC49B5E"/>
                <item android:offset="1.0" android:color="#FF7A5020"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Spine inner shadow (depth) -->
    <path android:pathData="M37,35 L31,31 L31,73 L37,78 Z"
          android:fillColor="#40180800"/>

    <!-- ③ Front cover — crimson, r=4dp rounded corners -->
    <!-- TL(38,35) TR(75,35) BR(75,78) BL(38,78) -->
    <path android:pathData="M42,35 L71,35 Q75,35 75,39 L75,74 Q75,78 71,78 L42,78 Q38,78 38,74 L38,39 Q38,35 42,35 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="42" android:startY="35"
                android:endX="71"   android:endY="78">
                <item android:offset="0.0" android:color="#FFC03030"/>
                <item android:offset="0.45" android:color="#FF8C1C1C"/>
                <item android:offset="1.0"  android:color="#FF520E0E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cover sheen — subtle diagonal highlight -->
    <path android:pathData="M42,35 L71,35 Q75,35 75,39 L75,74 Q75,78 71,78 L42,78 Q38,78 38,74 L38,39 Q38,35 42,35 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="38" android:startY="35"
                android:endX="62"   android:endY="59">
                <item android:offset="0.0" android:color="#18FFFFFF"/>
                <item android:offset="0.5" android:color="#06FFFFFF"/>
                <item android:offset="1.0" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cover inset border ornament -->
    <path android:pathData="M42,38 L71,38 Q73,38 73,40 L73,75 Q73,77 71,77 L42,77 Q40,77 40,75 L40,40 Q40,38 42,38 Z"
          android:fillColor="#00000000"
          android:strokeColor="#C49B5E"
          android:strokeWidth="0.55"
          android:strokeAlpha="0.30"/>

    <!-- Corner accent dots -->
    <path android:pathData="M42,40 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.42"/>
    <path android:pathData="M71,40 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.42"/>
    <path android:pathData="M42,76 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.42"/>
    <path android:pathData="M71,76 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"
          android:fillColor="#C49B5E" android:fillAlpha="0.42"/>

    <!-- Thin gold accent near top of cover -->
    <path android:pathData="M40,44 L73,44"
          android:strokeColor="#C49B5E"
          android:strokeWidth="0.55"
          android:strokeAlpha="0.20"
          android:fillColor="#00000000"/>

    <!-- ④ Spine highlight — bright edge where spine meets cover -->
    <path android:pathData="M38,35 L38,78"
          android:strokeWidth="1.4"
          android:strokeAlpha="0.80"
          android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="38" android:startY="35"
                android:endX="38"   android:endY="78">
                <item android:offset="0.0" android:color="#FFF8E898"/>
                <item android:offset="1.0" android:color="#FFC49B5E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-front edge highlight -->
    <path android:pathData="M38,35 L75,35"
          android:strokeColor="#F2D488"
          android:strokeWidth="0.7"
          android:strokeAlpha="0.28"
          android:fillColor="#00000000"/>

</vector>
